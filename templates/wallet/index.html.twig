{% extends 'base.html.twig' %}

{% block title %}portfele{% endblock %}

{% block body %}
    <div class="page-header">
        <h1><i class="bi bi-collection"></i> portfele</h1>
        <a href="{{ path('add_wallet') }}" class="btn-accent">
            <i class="bi bi-plus-lg"></i> nowy portfel
        </a>
    </div>

    {% if pagination.items|length > 0 %}
        <table class="app-table">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination, 'nazwa', 'wallet.name') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'saldo', 'wallet.balance') }}</th>
                <th>{{ knp_pagination_sortable(pagination, 'waluta', 'wallet.currency') }}</th>
                <th>akcje</th>
            </tr>
            </thead>
            <tbody>
            {% for wallet in pagination.items %}
                <tr>
                    <td class="mono">{{ wallet.name }}</td>
                    <td class="mono {% if (totals[wallet.id] ?? 0) >= 0 %}amount-positive{% else %}amount-negative{% endif %}">
                        {{ totals[wallet.id] ?? '0' }}
                    </td>
                    <td class="mono" style="color: var(--text-secondary);">{{ wallet.currency }}</td>
                    <td>
                        <a href="{{ path('wallet_view', {'id': wallet.id}) }}" class="btn-ghost">
                            przejdź
                        </a>
                        <a href="{{ path('edit_wallet', {'id': wallet.id}) }}" class="btn-ghost">
                            edytuj
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-3 d-flex justify-content-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    {% else %}
        <div class="app-card text-center" style="padding: 3rem;">
            <div style="font-size: 2rem; margin-bottom: 0.5rem;">📂</div>
            <p style="color: var(--text-secondary); margin-bottom: 1rem;">brak portfeli</p>
            <a href="{{ path('add_wallet') }}" class="btn-accent">utwórz pierwszy portfel</a>
        </div>
    {% endif %}
{% endblock %}
