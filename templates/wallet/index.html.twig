{% extends 'base.html.twig' %}

{% block title %}Lista portfeli{% endblock %}

{% block body %}
    <h1>Twoje portfele</h1>
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Nazwa</th>
            <th>Saldo</th>
            <th>Waluta</th>
            <th scope="col">Akcje</th>
        </tr>
        </thead>
        <tbody>
        {% for item in wallets %}
            <tr>
                <td>{{ item.name }}</td>
                <td>{{ item.balance }}</td>
                <td>{{ item.currency }}</td>

                <td><a href="{{ path('wallet_view',{id: item.id}) }}"class="btn btn-sm btn-outline-primary">Przejdź</a></td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3" class="text-center">Lista jest pusta</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>


{% endblock %}
