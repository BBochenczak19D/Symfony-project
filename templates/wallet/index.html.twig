{% extends 'base.html.twig' %}

{% block title %}Lista portfeli{% endblock %}

{% block body %}
    <h1>Twoje portfele</h1>
    {% if pagination is defined and pagination.items|length %}
        <table class="table table-striped">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination,'Nazwa','wallet.name') }}</th>
                <th>{{ knp_pagination_sortable(pagination,'Saldo','wallet.balance') }}</th>
                <th>{{ knp_pagination_sortable(pagination,'Waluta','wallet.currency') }}</th>
                <th scope="col">Akcje</th>
            </tr>
            </thead>
            <tbody>
            {% for wallet in pagination.items %}
                <tr>
                    <td>{{ wallet.name }}</td>
                    <td>{{ totals[wallet.id] ?? '0' }}</td>
                    <td>{{ wallet.currency }}</td>
                    <td><a href="{{ path('wallet_view',{id: wallet.id}) }}" class="btn btn-sm btn-outline-primary">Przejdź</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center">Lista jest pusta</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        <div class="navigation text-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    {% else %}
        <p>{{ 'message.empty_list'|trans }}</p>
    {% endif %}
{% endblock %}
