{% extends 'base.html.twig' %}

{% block title %}
    {{ 'title.operation_add'|trans }}
{% endblock %}

{% block body %}
    <h1>{{ 'title.operation_add'|trans }}</h1>
    {{ form_start(form) }}
    {{ form_widget(form) }}
    <div class="form-group row float-sm-right">
        <input type="submit" value="{{ 'action.save'|trans }}" class="btn btn-primary"/>
        <button><a href="{{ path('wallet_view',{id: wallet.id}) }}" class="btn btn-sm btn-secondary">{{ 'action.cancel'|trans }}</a></button>

    </div>

    {{ form_end(form) }}
{% endblock %}
