{% extends 'base.html.twig' %}

{% block title %}{{ wallet.name }}{% endblock %}

{% block body %}
    <a href="{{ path('wallet_index') }}" style="color: var(--text-muted); text-decoration: none; font-size: 13px;">
        <i class="bi bi-arrow-left"></i> {{ 'title.wallet_list'|trans }}
    </a>

    <div class="page-header mt-2">
        <div>
            <h1>{{ wallet.name }}</h1>
            <div class="d-flex align-items-baseline gap-2 mt-1">
                <span class="stat-label">{{ 'label.balance'|trans }}</span>
                <span class="stat-value {% if (totals[wallet.id] ?? 0) >= 0 %}amount-positive{% else %}amount-negative{% endif %}">
                    {{ totals[wallet.id] ?? '0' }}
                </span>
                <span style="color: var(--text-muted); font-family: 'JetBrains Mono', monospace;">{{ wallet.currency }}</span>
                {% if periodBalance is not null %}
                    <span style="margin-left:10px;font-size:12px;color:var(--text-muted);">{{ 'label.period_balance'|trans }}:</span>
                    <span class="mono {% if periodBalance >= 0 %}amount-positive{% else %}amount-negative{% endif %}" style="font-size:14px;font-weight:600;">
                        {{ periodBalance|number_format(2, '.', '') }}
                    </span>
                    <span style="color: var(--text-muted); font-family: 'JetBrains Mono', monospace; font-size:12px;">{{ wallet.currency }}</span>
                {% endif %}
            </div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            {% if app.request.querystring %}
                <a href="{{ path('wallet_view', {'id': wallet.id}) }}" class="btn-filter-clear">
                    <i class="bi bi-x"></i> {{ 'action.clear_filters'|trans }}
                </a>
            {% endif %}
            <a href="{{ path('add_operation', {'id': wallet.id}) }}" class="btn-accent">
                <i class="bi bi-plus-lg"></i> {{ 'action.new_transaction'|trans }}
            </a>
        </div>
    </div>

    <form method="get" action="{{ path('wallet_view', {'id': wallet.id}) }}" class="d-flex align-items-end gap-2 mb-3 flex-wrap">
        {% if filters.categoryId %}<input type="hidden" name="categoryId" value="{{ filters.categoryId }}">{% endif %}
        {% if filters.tagId %}<input type="hidden" name="tagId" value="{{ filters.tagId }}">{% endif %}
        <div class="d-flex flex-column" style="gap:2px;">
            <label style="font-size:11px;color:var(--text-muted);">{{ 'label.date_from'|trans }}</label>
            <input type="date" name="dateFrom" value="{{ filters.dateFrom ? filters.dateFrom|date('Y-m-d') : '' }}" style="font-family:'JetBrains Mono',monospace;font-size:13px;background:var(--card-bg);border:1px solid var(--border);color:var(--text-primary);border-radius:6px;padding:4px 8px;">
        </div>
        <div class="d-flex flex-column" style="gap:2px;">
            <label style="font-size:11px;color:var(--text-muted);">{{ 'label.date_to'|trans }}</label>
            <input type="date" name="dateTo" value="{{ filters.dateTo ? filters.dateTo|date('Y-m-d') : '' }}" style="font-family:'JetBrains Mono',monospace;font-size:13px;background:var(--card-bg);border:1px solid var(--border);color:var(--text-primary);border-radius:6px;padding:4px 8px;">
        </div>
        <button type="submit" class="btn-accent" style="height:32px;">{{ 'action.filter'|trans }}</button>
    </form>

    {% if is_granted('wallet_VIEW', wallet) %}
        {% if pagination.items|length > 0 %}
            <table class="app-table">
                <thead>
                <tr>
                    <th>{{ knp_pagination_sortable(pagination, 'label.amount'|trans, 'operation.amount') }}</th>
                    <th>{{ knp_pagination_sortable(pagination, 'label.date'|trans, 'operation.createdAt') }}</th>
                    <th>{{ knp_pagination_sortable(pagination, 'label.description'|trans, 'operation.description') }}</th>
                    <th>{{ 'label.category'|trans }}</th>
                    <th>{{ 'label.tags'|trans }}</th>
                    <th>{{ 'label.actions'|trans }}</th>
                </tr>
                </thead>
                <tbody>
                {% for item in pagination.items %}
                    <tr>
                        <td class="mono {% if item.amount >= 0 %}amount-positive{% else %}amount-negative{% endif %}">
                            {{ item.amount }} {{ item.wallet.currency }}
                        </td>
                        <td style="color: var(--text-secondary);">
                            {{ item.createdAt|date('d.m.Y H:i') }}
                        </td>
                        <td>{{ item.description }}</td>
                        <td>
                            {% if item.category %}
                                <a class="btn-tag category"
                                   href="{{ url('wallet_view', {'id': wallet.id, 'categoryId': item.category.id}) }}">
                                    {{ item.category.name }}
                                </a>
                            {% endif %}
                        </td>
                        <td>
                            {% if item.tags is defined and item.tags|length %}
                                <div class="d-flex gap-1 flex-wrap">
                                    {% for tag in item.tags %}
                                        <a class="btn-tag"
                                           href="{{ url('wallet_view', {'id': wallet.id, 'tagId': tag.id}) }}">
                                            {{ tag.name }}
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('edit_operation', {'walletId': wallet.id, 'id': item.id}) }}" class="btn-ghost">
                                {{ 'action.edit'|trans }}
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <div class="mt-3 d-flex justify-content-center">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% else %}
            <div class="app-card text-center" style="padding: 3rem;">
                <div style="font-size: 2rem; margin-bottom: 0.5rem;">📋</div>
                <p style="color: var(--text-secondary); margin-bottom: 1rem;">{{ 'message.no_transactions'|trans }}</p>
                <a href="{{ path('add_operation', {'id': wallet.id}) }}" class="btn-accent">{{ 'action.add_first'|trans }}</a>
            </div>
        {% endif %}
    {% else %}
        <div class="alert alert-danger">{{ 'message.no_access'|trans }}</div>
    {% endif %}
{% endblock %}
