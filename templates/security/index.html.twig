{% extends 'base.html.twig' %}

{% block title %}{{ 'title.user_list'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'title.user_list'|trans }}</h1>

    <table class="table table-striped">
        <thead>
        <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Role</th>
            <th>Akcje</th>
        </tr>
        </thead>
        <tbody>
        {% for user in pagination.items %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>
                    {% for role in user.roles %}
                        <span class="badge bg-{% if role == 'ROLE_ADMIN' %}danger{% else %}secondary{% endif %}">
                            {{ role }}
                        </span>
                    {% endfor %}
                </td>
                <td>
                    <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-secondary">
                        {{ 'action.edit'|trans }}
                    </a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center">{{ 'message.no_users'|trans }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="navigation text-center">
        {{ knp_pagination_render(pagination) }}
    </div>
{% endblock %}
