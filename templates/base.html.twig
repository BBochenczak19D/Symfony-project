<!DOCTYPE html>
<html lang="pl" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Portfele{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>💰</text></svg>">
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
              rel="stylesheet"
              integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
              crossorigin="anonymous">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
              rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    {% endblock %}
    <style>
        :root {
            --bg-primary: #0d0d0d;
            --bg-secondary: #161616;
            --bg-card: #1a1a1a;
            --bg-hover: #222222;
            --border-color: #2a2a2a;
            --border-light: #333333;
            --text-primary: #e0e0e0;
            --text-secondary: #888888;
            --text-muted: #555555;
            --accent-green: #4ade80;
            --accent-blue: #60a5fa;
            --accent-yellow: #facc15;
            --accent-red: #f87171;
            --accent-purple: #c084fc;
            --accent-orange: #fb923c;
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Inter', -apple-system, sans-serif;
            font-size: 14px;
            line-height: 1.6;
        }

        /* --- NAVBAR --- */
        .app-nav {
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
            padding: 0.6rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(12px);
        }
        .app-nav .brand {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            font-size: 1rem;
            color: var(--text-primary);
            text-decoration: none;
            letter-spacing: -0.5px;
        }
        .app-nav .brand i { color: var(--accent-yellow); }
        .app-nav .nav-links {
            display: flex;
            gap: 0.25rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .app-nav .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            transition: all 0.15s;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .app-nav .nav-links a:hover {
            color: var(--text-primary);
            background: var(--bg-hover);
        }
        .app-nav .nav-links a.active {
            color: var(--text-primary);
            background: var(--bg-card);
        }
        .app-nav .nav-links .admin-link { color: var(--accent-yellow); }
        .app-nav .nav-links .admin-link:hover { color: var(--accent-yellow); background: rgba(250, 204, 21, 0.1); }

        .app-nav .user-section {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .app-nav .user-email {
            color: var(--text-secondary);
            font-size: 12px;
            font-family: 'JetBrains Mono', monospace;
        }
        .app-nav .user-btn {
            color: var(--text-secondary);
            background: none;
            border: 1px solid var(--border-color);
            font-size: 12px;
            padding: 0.3rem 0.6rem;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.15s;
        }
        .app-nav .user-btn:hover {
            color: var(--text-primary);
            border-color: var(--border-light);
            background: var(--bg-hover);
        }
        .app-nav .user-btn.logout:hover { border-color: var(--accent-red); color: var(--accent-red); }

        /* --- LAYOUT --- */
        .app-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }

        /* --- HEADINGS --- */
        h1, h2, h3, h4 {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            letter-spacing: -0.5px;
        }
        h1 { font-size: 1.5rem; }
        h4 { font-size: 1.1rem; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-color);
        }
        .page-header h1 { margin: 0; }

        /* --- BUTTONS --- */
        .btn-accent {
            background: var(--accent-green);
            color: #000;
            border: none;
            font-size: 13px;
            font-weight: 600;
            padding: 0.45rem 1rem;
            border-radius: 6px;
            transition: all 0.15s;
        }
        .btn-accent:hover { background: #22c55e; color: #000; }

        .btn-ghost {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
            font-size: 13px;
            padding: 0.4rem 0.85rem;
            border-radius: 6px;
            transition: all 0.15s;
            text-decoration: none;
        }
        .btn-ghost:hover {
            color: var(--text-primary);
            border-color: var(--border-light);
            background: var(--bg-hover);
        }
        .btn-ghost.danger:hover { border-color: var(--accent-red); color: var(--accent-red); }

        .btn-tag {
            background: var(--bg-hover);
            color: var(--accent-blue);
            border: 1px solid var(--border-color);
            font-size: 12px;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            text-decoration: none;
            transition: all 0.15s;
            font-family: 'JetBrains Mono', monospace;
        }
        .btn-tag:hover { background: rgba(96, 165, 250, 0.15); color: var(--accent-blue); border-color: var(--accent-blue); }
        .btn-tag.category { color: var(--accent-purple); }
        .btn-tag.category:hover { background: rgba(192, 132, 252, 0.15); border-color: var(--accent-purple); color: var(--accent-purple); }

        .btn-filter-clear {
            background: transparent;
            color: var(--text-muted);
            border: 1px dashed var(--border-color);
            font-size: 12px;
            padding: 0.3rem 0.7rem;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.15s;
        }
        .btn-filter-clear:hover { color: var(--text-secondary); border-color: var(--border-light); }

        /* --- TABLES --- */
        .app-table {
            width: 100%;
            border-collapse: collapse;
        }
        .app-table thead th {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            padding: 0.6rem 1rem;
            border-bottom: 1px solid var(--border-color);
        }
        .app-table thead th a { color: var(--text-muted) !important; text-decoration: none; }
        .app-table thead th a:hover { color: var(--text-secondary) !important; }
        .app-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.1s;
        }
        .app-table tbody tr:hover { background: var(--bg-secondary); }
        .app-table tbody td {
            padding: 0.75rem 1rem;
            font-size: 13px;
            vertical-align: middle;
        }
        .app-table .mono {
            font-family: 'JetBrains Mono', monospace;
        }
        .app-table .amount-positive { color: var(--accent-green); }
        .app-table .amount-negative { color: var(--accent-red); }

        /* --- CARDS --- */
        .app-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
        }

        /* --- FORMS --- */
        .form-control, .form-select {
            background: var(--bg-secondary) !important;
            border: 1px solid var(--border-color) !important;
            color: var(--text-primary) !important;
            font-size: 13px;
            border-radius: 6px;
            padding: 0.5rem 0.75rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent-blue) !important;
            box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.15) !important;
        }
        .form-label {
            font-size: 12px;
            font-weight: 500;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 0.3rem;
        }

        /* --- ALERTS --- */
        .alert {
            font-size: 13px;
            border-radius: 6px;
            border: 1px solid var(--border-color);
        }
        .alert-success { background: rgba(74, 222, 128, 0.1); color: var(--accent-green); border-color: rgba(74, 222, 128, 0.2); }
        .alert-danger { background: rgba(248, 113, 113, 0.1); color: var(--accent-red); border-color: rgba(248, 113, 113, 0.2); }
        .alert-info { background: rgba(96, 165, 250, 0.1); color: var(--accent-blue); border-color: rgba(96, 165, 250, 0.2); }

        /* --- BADGES --- */
        .badge-role {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            font-weight: 500;
        }
        .badge-admin { background: rgba(250, 204, 21, 0.15); color: var(--accent-yellow); }
        .badge-user { background: rgba(96, 165, 250, 0.15); color: var(--accent-blue); }

        /* --- PAGINATION --- */
        .pagination { gap: 0.2rem; }
        .page-link {
            background: var(--bg-secondary) !important;
            border: 1px solid var(--border-color) !important;
            color: var(--text-secondary) !important;
            font-size: 13px;
            border-radius: 6px !important;
            padding: 0.35rem 0.7rem;
        }
        .page-link:hover { color: var(--text-primary) !important; background: var(--bg-hover) !important; }
        .page-item.active .page-link {
            background: var(--accent-blue) !important;
            border-color: var(--accent-blue) !important;
            color: #000 !important;
        }

        /* --- STAT BOX --- */
        .stat-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
        }
        .stat-value {
            font-size: 1.5rem;
            font-weight: 600;
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-primary);
        }

        /* --- MISC --- */
        a { color: var(--accent-blue); }
        a:hover { color: #93bbfd; }
        hr { border-color: var(--border-color); }
        .text-muted { color: var(--text-muted) !important; }

        /* responsive navbar */
        @media (max-width: 768px) {
            .app-nav .inner { flex-direction: column; gap: 0.5rem; }
            .app-nav .nav-links { flex-wrap: wrap; }
            .app-nav .user-section { justify-content: flex-end; }
        }
    </style>
</head>
<body>

{% if app.user %}
    <nav class="app-nav">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
                <a class="brand" href="{{ path('wallet_index') }}">
                    <i class="bi bi-wallet2"></i> portfel.app
                </a>
                <ul class="nav-links">
                    <li><a href="{{ path('wallet_index') }}"><i class="bi bi-collection"></i> {{ 'title.wallet_list'|trans }}</a></li>
                    <li><a href="{{ path('category_index') }}"><i class="bi bi-tags"></i> {{ 'title.category_list'|trans }}</a></li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li><a href="{{ path('admin_user_index') }}" class="admin-link"><i class="bi bi-people-fill"></i> {{ 'title.user_list'|trans }}</a></li>
                    {% endif %}
                </ul>
            </div>
            <div class="user-section">
                <span class="user-email">{{ app.user.email }}</span>
                <a href="{{ path('app_profile') }}" class="user-btn"><i class="bi bi-gear"></i> {{ 'title.profile'|trans }}</a>
                <a href="{{ path('app_logout') }}" class="user-btn logout"><i class="bi bi-box-arrow-right"></i></a>
            </div>
        </div>
    </nav>
{% endif %}

<div class="app-container">
    {% for type, messages in app.session.flashBag.all %}
        {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>

{% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
{% endblock %}
</body>
</html>
