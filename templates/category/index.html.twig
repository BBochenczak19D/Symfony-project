{% extends 'base.html.twig' %}

{% block title %}kategorie{% endblock %}

{% block body %}
    <div class="page-header">
        <h1><i class="bi bi-tags"></i> kategorie</h1>
        <a href="{{ path('add_category') }}" class="btn-accent">
            <i class="bi bi-plus-lg"></i> nowa kategoria
        </a>
    </div>

    {% if pagination is defined and pagination.items|length %}
        <table class="app-table">
            <thead>
            <tr>
                <th>{{ knp_pagination_sortable(pagination, 'nazwa', 'category.name') }}</th>
                <th>akcje</th>
            </tr>
            </thead>
            <tbody>
            {% for category in pagination.items %}
                <tr>
                    <td class="mono">
                        <span style="color: var(--accent-purple);">●</span> {{ category.name }}
                    </td>
                    <td>
                        {% if is_granted('Category_EDIT', category) %}
                            <a href="{{ path('edit_category', {'id': category.id}) }}" class="btn-ghost">edytuj</a>
                        {% endif %}
                        {% if is_granted('Category_DELETE', category) %}
                            <a href="{{ path('delete_category', {'id': category.id}) }}" class="btn-ghost danger">usuń</a>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="mt-3 d-flex justify-content-center">
            {{ knp_pagination_render(pagination) }}
        </div>
    {% else %}
        <div class="app-card text-center" style="padding: 3rem;">
            <div style="font-size: 2rem; margin-bottom: 0.5rem;">🏷️</div>
            <p style="color: var(--text-secondary); margin-bottom: 1rem;">brak kategorii</p>
            <a href="{{ path('add_category') }}" class="btn-accent">utwórz pierwszą</a>
        </div>
    {% endif %}
{% endblock %}
